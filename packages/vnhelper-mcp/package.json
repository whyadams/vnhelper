{
  "name": "vnhelper-mcp",
  "version": "0.4.0",
  "description": "MCP server exposing VnHelper (Supabase) workspace operations to Claude.",
  "private": true,
  "type": "module",
  "bin": {
    "vnhelper-mcp": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli.js",
    "login": "node dist/cli.js login",
    "bundle:win": "bun build src/cli.ts --compile --target=bun-windows-x64 --outfile dist/vnhelper-mcp.exe",
    "bundle:mac": "bun build src/cli.ts --compile --target=bun-darwin-arm64 --outfile dist/vnhelper-mcp",
    "bundle:linux": "bun build src/cli.ts --compile --target=bun-linux-x64 --outfile dist/vnhelper-mcp"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@supabase/supabase-js": "^2.105.1",
    "marked": "^14.1.4",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "~5.8.3"
  }
}
