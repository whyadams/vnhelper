{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main, widget, and simulator windows. The fs:* permissions are scoped to '**' because the only two consumers — TranslationsSidebar (Ren'Py translation folder import/export at src/components/translations/TranslationsSidebar.tsx) and PhotosScreen (local photo library at src/components/photos/PhotosScreen.tsx) — operate on a folder the user picks at runtime via the dialog plugin. That folder lives anywhere on disk by design (e.g. an external drive holding a Ren'Py project's /game/tl/ tree), so $APPDATA / $DOCUMENT / $DOWNLOAD scoping would break both flows. fs:allow-exists was previously granted but is not called anywhere — removed.",
  "windows": ["main", "widget", "simulator"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-minimize",
    "core:window:allow-unminimize",
    "core:window:allow-maximize",
    "core:window:allow-unmaximize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-set-focus",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-always-on-top",
    "core:window:allow-set-size",
    "core:window:allow-set-position",
    "core:window:allow-get-all-windows",
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "core:webview:default",
    "core:webview:allow-create-webview-window",
    "opener:default",
    "updater:default",
    "process:default",
    "process:allow-restart",
    "autostart:default",
    "autostart:allow-enable",
    "autostart:allow-disable",
    "autostart:allow-is-enabled",
    "notification:default",
    "notification:allow-notify",
    "notification:allow-is-permission-granted",
    "notification:allow-request-permission",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "fs:allow-read-file",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "fs:allow-stat",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://localhost:*" },
        { "url": "http://127.0.0.1:*" },
        { "url": "https://localhost:*" },
        { "url": "https://127.0.0.1:*" }
      ]
    }
  ]
}
